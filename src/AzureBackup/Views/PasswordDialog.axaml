<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="AzureBackup.Views.PasswordDialog"
        Title="Unlock Azure Backup"
        Width="400" MinHeight="200"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="BorderOnly">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="24">
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Enter Password" FontSize="20" FontWeight="SemiBold" 
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        
        <!-- Description -->
        <TextBlock Grid.Row="1" Text="Enter your password to unlock encryption and connect to Azure Storage."
                   TextWrapping="Wrap" Opacity="0.7" HorizontalAlignment="Center" 
                   TextAlignment="Center" Margin="0,0,0,16"/>
        
        <!-- Password Entry -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
            <TextBox x:Name="PasswordBox" 
                     PasswordChar="*" 
                     Watermark="Password"
                     RevealPassword="{Binding #ShowPasswordToggle.IsChecked}"
                     Margin="0,0,8,0"/>
            <ToggleButton x:Name="ShowPasswordToggle" Grid.Column="1" Content="Show" 
                          ToolTip.Tip="Show/Hide password" Padding="8,6"/>
        </Grid>
        
        <!-- Error Message -->
        <TextBlock Grid.Row="3" x:Name="ErrorText" 
                   Foreground="Red" FontSize="12"
                   TextWrapping="Wrap" TextAlignment="Center"
                   HorizontalAlignment="Stretch" Margin="0,8,0,0"
                   IsVisible="False"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="Unlock" IsDefault="True" Classes="primary" 
                    Width="100" HorizontalContentAlignment="Center"/>
            <Button x:Name="CancelButton" Content="Cancel" IsCancel="True" 
                    Width="100" HorizontalContentAlignment="Center"/>
        </StackPanel>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>
</Window>
