<Project Sdk="Microsoft.NET.Sdk">


  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <DefineConstants>$(DefineConstants);DIAGNOSTICLOG</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Lets SecureCloudBackup.Tests reach internal types - the SqliteBackend
      and other Backends namespace code that is not part of the public
      surface. SecureCloudBackup.Benchmarks uses the same bridge for the
      throughput and memory benchmarks.
    -->
    <InternalsVisibleTo Include="SecureCloudBackup.Tests" />
    <InternalsVisibleTo Include="SecureCloudBackup.Benchmarks" />
    <InternalsVisibleTo Include="SecureCloudBackup.Storage.Azure" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.72" />
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.6" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
    <PackageReference Include="System.IO.Hashing" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SecureCloudBackup.Crypto\SecureCloudBackup.Crypto.csproj" />
    <ProjectReference Include="..\SecureCloudBackup.SqliteInterop\SecureCloudBackup.SqliteInterop.csproj" />
  </ItemGroup>


</Project>
