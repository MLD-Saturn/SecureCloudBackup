<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SecureCloudBackup.App"
             xmlns:local="using:SecureCloudBackup"
             xmlns:vm="using:SecureCloudBackup.ViewModels"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- Global emoji font fallback: the default Avalonia/FluentTheme font (Segoe UI / system default)
             lacks emoji glyphs on some platforms. Adding platform emoji fonts as fallbacks ensures
             U+1Fxxx codepoints render everywhere (Windows, macOS, Linux). -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="avares://Avalonia.Themes.Fluent/Fonts#Inter,Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji"/>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- Brush wrappers for system accent colors — Avalonia's SystemAccentColor is a Color,
             but Foreground/Background/BorderBrush properties require a Brush. -->
        <SolidColorBrush x:Key="AppAccentBrush" Color="{DynamicResource SystemAccentColor}"/>
        <SolidColorBrush x:Key="AppAccentLight3Brush" Color="{DynamicResource SystemAccentColorLight3}"/>

        <vm:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <vm:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <vm:BoolToViewModeConverter x:Key="BoolToViewModeConverter"/>
        <vm:BytesToStringConverter x:Key="BytesToStringConverter"/>
        <vm:PendingToColorConverter x:Key="PendingToColorConverter"/>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico"
                      ToolTipText="Azure Backup">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show Azure Backup" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
